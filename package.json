{
  "name": "global-city-times",
  "private": true,
  "version": "1.0.0",
  "description": "Global city time and market intelligence desktop app",
  "author": "Codex",
  "type": "module",
  "main": "desktop/electron/main.js",
  "scripts": {
    "dev": "vite",
    "dev:web": "vite",
    "api": "node server/index.js",
    "build": "vite build",
    "preview": "vite preview",
    "desktop": "electron .",
    "desktop:dev": "electron .",
    "desktop:pack": "npm run build && electron-builder --win nsis",
    "desktop:portable": "npm run build && electron-builder --win portable"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.1",
    "electron": "^31.7.7",
    "electron-builder": "^24.13.3",
    "vite": "^5.4.8"
  },
  "build": {
    "appId": "com.codex.globalcitytimes",
    "productName": "Global City Times",
    "directories": {
      "output": "release",
      "buildResources": "assets"
    },
    "artifactName": "Global-City-Times-${version}-Setup.${ext}",
    "asar": true,
    "compression": "normal",
    "files": [
      "dist/**/*",
      "desktop/**/*",
      "server/**/*",
      "src/data/**/*",
      "package.json"
    ],
    "win": {
      "icon": "assets/app-icon.ico",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "runAfterFinish": false,
      "installerIcon": "assets/app-icon.ico",
      "uninstallerIcon": "assets/app-icon.ico",
      "installerHeaderIcon": "assets/app-icon.ico"
    }
  }
}
